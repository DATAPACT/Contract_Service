Create a .env file and add following items:

MONGO_USER=root
MONGO_PASSWORD=your_password
MONGO_HOST=your_machine_ip
MONGO_PORT=27017

# Old code:
# API_AUTHENTICATION_URL=http://authentication-service:8899
#
# New code:
# contract-service now validates bearer tokens directly with Keycloak.
KEYCLOAK_ISSUER=https://your-keycloak-host/realms/your-realm
KEYCLOAK_JWKS_URL=https://your-keycloak-host/realms/your-realm/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=contract-service
KEYCLOAK_CLIENT_ID=contract-service
# Optional: set when the Keycloak client is confidential and requires a secret
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret

# Both contracts and users are stored in the same MongoDB.
MONGO_DB=dips_services

API_CONTRACT_SERVICE_URL=http://your_machine_ip:8006

OPENAI_API_KEY=your_OpenAI_key
MODEL_NAME=gpt-5-nano
#o4-mini
#gpt-5-nano
#MODEL_NAME=gpt-4o-mini
